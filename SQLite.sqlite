using System;
using System.Data.SQLite;

public class RecentFilesManager
{
    private string connectionString = "Data Source=your_database.db;Version=3;";

    public void InsertRecentFile(string filename)
    {
        using (SQLiteConnection connection = new SQLiteConnection(connectionString))
        {
            connection.Open();
            using (SQLiteCommand cmd = connection.CreateCommand())
            {
                cmd.CommandText = "INSERT INTO RecentFiles (filename) VALUES (@filename)";
                cmd.Parameters.AddWithValue("@filename", filename);
                cmd.ExecuteNonQuery();
            }
        }
    }

    public List<string> GetRecentFiles(int limit = 5)
    {
        List<string> recentFiles = new List<string>();

        using (SQLiteConnection connection = new SQLiteConnection(connectionString))
        {
            connection.Open();
            using (SQLiteCommand cmd = connection.CreateCommand())
            {
                cmd.CommandText = "SELECT filename FROM RecentFiles ORDER BY opened_at DESC LIMIT @limit";
                cmd.Parameters.AddWithValue("@limit", limit);

                using (SQLiteDataReader reader = cmd.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        recentFiles.Add(reader["filename"].ToString());
                    }
                }
            }
        }

        return recentFiles;
    }
}
